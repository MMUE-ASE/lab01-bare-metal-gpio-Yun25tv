# ,--------------------------------------------.
# |  Lab 1  .  Guided Questions Answers        |
# |  STM32F412ZG  .  NUCLEO-144                |
# '--------------------------------------------'
#
# Fill in each value and commit to get automatic feedback.
# Do not modify the variable names.
#
# Hex format  →  use 0x prefix  (e.g. 0x40020400)
# Int format  →  decimal number  (e.g. 14)
# Pin format  →  letter + number  (e.g. PA5)

# --- Block 1 . Board hardware ---
B1_PIN=PC13
LD2_PIN=PB7
B1_IDLE_LEVEL=1
B1_PRESSED_LEVEL=0

# --- Block 2 . Memory map ---
RCC_BASE=0x40023800
GPIOB_BASE=0x40020400
GPIOC_BASE=0x40020800

# --- Block 3 . Peripheral clock (RCC_AHB1ENR) ---
GPIOBEN_BIT=1
GPIOCEN_BIT=1
AHB1ENR_MASK=0x00000006

# --- Block 4 . Pin mode (GPIOx_MODER) ---
MODER_BITS_PER_PIN=2
MODER_INPUT_VAL=00
MODER_OUTPUT_VAL=01
PB7_MODER_BIT=14
PC13_MODER_BIT=26

# --- Block 5 . Read and write (IDR / ODR) ---
IDR_OFFSET=0x10
ODR_OFFSET=0x14
PC13_IDR_BIT=13
PB7_ODR_BIT=7
